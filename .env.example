# ─────────────────────────────────────────────────────────────────────────────
# Tradie Systems Co — environment variables
# Copy to `.env.local` for local dev. Set the same in Vercel for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sanity CMS ───────────────────────────────────────────────────────────────
# Create a free project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Optional: only needed if you want to preview drafts or write from the app.
SANITY_API_READ_TOKEN=

# ── Booking ──────────────────────────────────────────────────────────────────
# Cal.com or Calendly URL — used in CTAs across the site and in the contact form.
NEXT_PUBLIC_BOOKING_URL=https://cal.com/tradiesystemsco/strategy-call

# ── Contact form ─────────────────────────────────────────────────────────────
CONTACT_EMAIL=hello@tradiesystemsco.com.au

# Resend (recommended) — https://resend.com
RESEND_API_KEY=

# Optional: ping a Slack channel on every new lead.
SLACK_WEBHOOK_URL=

# ── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 — https://analytics.google.com
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Microsoft Clarity — https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=

# ── Site ─────────────────────────────────────────────────────────────────────
# Used by metadata when generating absolute URLs in non-production previews.
NEXT_PUBLIC_SITE_URL=https://tradiesystemsco.com.au
